generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanTier {
  FREE
  PRO
  BUSINESS
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  /// Personal preference: use AI for timeline polish + smart notifications
  aiEnabled    Boolean  @default(true)
  /// Subscription tier
  plan         PlanTier @default(FREE)
  planExpiresAt DateTime?
  /// Total uploaded file bytes attributed to this user
  storageBytesUsed BigInt @default(0)
  createdAt    DateTime @default(now())

  trips                 TripMember[]
  expensesPaid          TripExpense[]          @relation("ExpensesPaid")
  expenseParticipations ExpenseParticipant[]
  decisionsCreated      Decision[]             @relation("DecisionsCreated")
  decisionVotes         DecisionVote[]         @relation("DecisionVotesByUser")
  linksCreated          TripLink[]             @relation("LinksCreated")
  timelineEvents        TimelineEvent[]        @relation("TimelineCreatedBy")
  flightsCreated        TripFlight[]           @relation("FlightsCreated")
  notifications         Notification[]
  usageMonths           UsageMonth[]
  biometricCredentials  BiometricCredential[]
}

model BiometricCredential {
  id          String   @id @default(uuid())
  userId      String
  credentialId String  @unique
  publicKey   String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Monthly usage counters (AI calls, etc.)
model UsageMonth {
  id        String   @id @default(uuid())
  userId    String
  /// Format YYYY-MM
  period    String
  aiCalls   Int      @default(0)
  /// Optional: bytes uploaded this month
  storageBytesAdded BigInt @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([userId])
}

/// Super-admin editable plan limits (overrides defaults in code)
model PlanConfig {
  id                  String  @id // FREE | PRO | BUSINESS
  nameHe              String
  maxTrips            Int
  maxMembersPerTrip   Int
  maxAiCallsPerMonth  Int
  maxStorageBytes     BigInt
  aiIncluded          Boolean @default(true)
  updatedAt           DateTime @updatedAt
}

model Trip {
  id              String     @id @default(uuid())
  name            String
  startDate       DateTime?
  endDate         DateTime?
  status          TripStatus @default(PLAN)
  inviteCode      String     @unique @default(uuid())
  defaultCurrency String     @default("ILS")
  ownerId         String     @default("")
  /// Trip-level AI switch (admin). When false, no AI for this trip.
  aiEnabled       Boolean    @default(true)
  createdAt       DateTime   @default(now())

  members           TripMember[]
  expenses          TripExpense[]
  places            TripPlace[]
  decisions         Decision[]
  links             TripLink[]
  items             TripItem[]
  plannerActivities PlannerActivity[]
  plannerEvents     PlannerEvent[]
  timelineEvents    TimelineEvent[]
  flights           TripFlight[]
  notifications     Notification[]
}

enum TripStatus {
  PLAN
  LIVE
  FINISHED
  CANCELED
}

model TripMember {
  id       String     @id @default(uuid())
  userId   String
  tripId   String
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  user     User @relation(fields: [userId], references: [id])
  trip     Trip @relation(fields: [tripId], references: [id])

  @@unique([userId, tripId])
}

enum MemberRole {
  ADMIN
  MEMBER
}


// ===== הוצאות (Splitwise) =====

model TripExpense {
  id           String   @id @default(uuid())
  tripId       String
  paidByUserId String
  amount       Float
  currency     String   @default("ILS")
  exchangeRate Float    @default(1)   // כמה שקלים שווה יחידת מטבע
  amountILS    Float                  // amount * exchangeRate
  description  String
  category     String   @default("other")
  expenseDate  DateTime @default(now())
  createdAt    DateTime @default(now())

  trip         Trip                 @relation(fields: [tripId], references: [id])
  paidBy       User                 @relation("ExpensesPaid", fields: [paidByUserId], references: [id])
  participants ExpenseParticipant[]
}

model ExpenseParticipant {
  id        String      @id @default(uuid())
  expenseId String
  userId    String

  expense   TripExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
}

// ===== מקור אחיד למקומות / פעילויות / אירועים =====

model TripItem {
  id           String   @id @default(uuid())
  tripId       String
  kind         String   @default("activity")
  name         String
  description  String?
  category     String   @default("other")
  mapsUrl      String?
  url          String?
  location     String?
  lat          Float?
  lng          Float?
  emoji        String   @default("📌")
  color        String   @default("blue")
  cost         String?
  durationMins Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trip              Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  places            TripPlace[]
  plannerActivities PlannerActivity[]
  plannerEvents     PlannerEvent[]

  @@index([tripId])
  @@index([tripId, name])
  @@index([tripId, mapsUrl])
}

// ===== מפת טיול =====

model TripPlace {
  id        String   @id @default(uuid())
  itemId    String?
  tripId    String
  name      String
  lat       Float
  lng       Float
  notes     String?
  mapsUrl   String?
  date      String?
  order     Int      @default(0)
  category  String   @default("other")
  createdAt DateTime @default(now())

  trip      Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  item      TripItem?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
  photos    PlacePhoto[]

  @@index([itemId])
}

model PlacePhoto {
  id        String    @id @default(uuid())
  placeId   String
  url       String
  caption   String?
  createdAt DateTime  @default(now())

  place     TripPlace @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

// ===== קישורים מרוכזים =====

enum TripLinkType {
  FLIGHT
  HOTEL
  CAR
  ACTIVITY
  RESTAURANT
  BAR
  MAP
  INSURANCE
  DOCUMENT
  PAYMENT
  OTHER
}

enum TripLinkStatus {
  SAVED
  PENDING
  BOOKED
  PAID
  MISSING
  CANCELLED
}

model TripLink {
  id                String         @id @default(uuid())
  tripId            String
  title             String
  description       String?
  url               String?
  type              TripLinkType   @default(OTHER)
  status            TripLinkStatus @default(SAVED)
  providerName      String?
  startDate         DateTime?
  endDate           DateTime?
  estimatedCost     Float?
  currency          String?
  responsibleUserId String?
  notes             String?
  isPinned          Boolean        @default(false)
  isPrivate         Boolean        @default(false)
  fileUrl           String?
  fileName          String?
  decisionId        String?
  createdByUserId   String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  trip      Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User @relation("LinksCreated", fields: [createdByUserId], references: [id])
}

// ===== החלטות =====

enum DecisionStatus {
  VOTING
  DECIDED
}

enum DecisionType {
  YES_NO
  SINGLE_CHOICE
  MULTI_CHOICE
  TOP3
}

enum DecisionCategory {
  DESTINATION
  DATES
  HOTEL
  TRANSPORT
  ACTIVITY
  BUDGET
  OTHER
}

model Decision {
  id              String           @id @default(uuid())
  tripId          String
  title           String
  description     String?
  category        DecisionCategory @default(OTHER)
  status          DecisionStatus   @default(VOTING)
  type            DecisionType
  finalDecision   String?
  finalOptionId   String?
  dueDate         DateTime?
  actionNote      String?
  isSecretVote           Boolean          @default(false)
  hideResultsUntilClosed Boolean          @default(false)
  createdByUserId String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  decidedAt       DateTime?

  trip      Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User             @relation("DecisionsCreated", fields: [createdByUserId], references: [id])
  options   DecisionOption[]
  votes     DecisionVote[]
}

model DecisionOption {
  id          String   @id @default(uuid())
  decisionId  String
  text        String
  description String?
  createdAt   DateTime @default(now())

  decision Decision       @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  votes    DecisionVote[]
}

model DecisionVote {
  id         String   @id @default(uuid())
  decisionId String
  optionId   String
  userId     String
  rank       Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  decision Decision       @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  option   DecisionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user     User           @relation("DecisionVotesByUser", fields: [userId], references: [id])

  @@unique([decisionId, optionId, userId])
}

// ===== מתכנן טיול =====

model PlannerActivity {
  id           String   @id @default(uuid())
  itemId       String?
  tripId       String
  name         String
  emoji        String   @default("📌")
  location     String?
  description  String?
  durationMins Int      @default(60)
  cost         String?
  category     String   @default("other")
  mapsUrl      String?
  url          String?
  color        String   @default("blue")
  createdAt    DateTime @default(now())

  trip   Trip                  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  item   TripItem?             @relation(fields: [itemId], references: [id], onDelete: SetNull)
  events PlannerEvent[]
  files  PlannerActivityFile[]
  votes  PlannerActivityVote[]

  @@index([itemId])
}

model PlannerActivityVote {
  id         String   @id @default(uuid())
  activityId String
  tripId     String
  userId     String
  vote       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  activity PlannerActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([tripId])
}

model PlannerActivityFile {
  id           String   @id @default(uuid())
  activityId   String
  filename     String
  originalName String
  mimeType     String   @default("application/octet-stream")
  size         Int      @default(0)
  createdAt    DateTime @default(now())

  activity PlannerActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model PlannerEvent {
  id           String   @id @default(uuid())
  itemId       String?
  tripId       String
  activityId   String?
  title        String
  date         String
  startMinute  Int      @default(0)
  durationMins Int      @default(60)
  color        String   @default("blue")
  notes        String?
  allDay       Boolean  @default(false)
  url          String?
  mapsUrl      String?
  cost         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trip     Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  item     TripItem?          @relation(fields: [itemId], references: [id], onDelete: SetNull)
  activity PlannerActivity?   @relation(fields: [activityId], references: [id], onDelete: SetNull)
  files    PlannerEventFile[]

  @@index([itemId])
}

model PlannerEventFile {
  id           String   @id @default(uuid())
  eventId      String
  filename     String
  originalName String
  mimeType     String   @default("application/octet-stream")
  size         Int      @default(0)
  createdAt    DateTime @default(now())

  event PlannerEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ===== טיסות =====

model TripFlight {
  id                String    @id @default(uuid())
  tripId            String
  flightNumber      String
  flightDate        DateTime?
  direction         String    @default("outbound") // outbound | return | other
  airline           String?
  departureAirport  String?
  arrivalAirport    String?
  departureAt       DateTime?
  arrivalAt         DateTime?
  notes             String?
  liveData          Json?
  liveFetchedAt     DateTime?
  createdByUserId   String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  trip      Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User @relation("FlightsCreated", fields: [createdByUserId], references: [id])

  @@index([tripId])
  @@index([tripId, flightNumber])
}

// ===== ציר זמן =====

enum TimelineEventType {
  MEMBER_JOINED
  DECISION_CLOSED
  LINK_ADDED
  PLACE_ADDED
  EXPENSE_ADDED
  PHOTO_UPLOADED
  MEMORY
  AI_RECAP
  AI_NOTE
}

model TimelineEvent {
  id              String            @id @default(uuid())
  tripId          String
  type            TimelineEventType
  /// UI filter bucket: expenses | places | photos | decisions | documents | members | memory | ai
  category        String
  title           String
  description     String?
  emoji           String            @default("📌")
  isPrivate       Boolean           @default(false)
  /// True when title/description was written or polished by AI
  aiGenerated     Boolean           @default(false)
  createdByUserId String?
  refType         String?
  refId           String?
  metadata        Json?
  occurredAt      DateTime          @default(now())
  createdAt       DateTime          @default(now())

  trip      Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User? @relation("TimelineCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tripId, occurredAt])
  @@index([tripId, category])
  @@index([tripId, type])
}

// ===== התראות =====

model Notification {
  id        String   @id @default(uuid())
  userId    String
  tripId    String?
  type      String   @default("system") // system | ai | decision | expense | member | memory | flight
  title     String
  body      String?
  emoji     String   @default("🔔")
  href      String?
  isRead    Boolean  @default(false)
  /// True when text was AI-generated/polished
  aiGenerated Boolean @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip? @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@index([tripId])
}
