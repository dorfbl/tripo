generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime @default(now())

  trips              TripMember[]
  answers            QuestionAnswer[]
  votes              DestinationVote[]
  expensesPaid       TripExpense[]          @relation("ExpensesPaid")
  expenseParticipations ExpenseParticipant[]
  decisionsCreated   Decision[]             @relation("DecisionsCreated")
  decisionVotes      DecisionVote[]         @relation("DecisionVotesByUser")
  linksCreated       TripLink[]             @relation("LinksCreated")
}

model Trip {
  id              String     @id @default(uuid())
  name            String
  startDate       DateTime?
  endDate         DateTime?
  status          TripStatus @default(PLANNING)
  inviteCode      String     @unique @default(uuid())
  defaultCurrency String     @default("ILS")
  createdAt       DateTime   @default(now())

  members      TripMember[]
  destinations SuggestedDestination[]
  expenses     TripExpense[]
  places       TripPlace[]
  decisions    Decision[]
  links        TripLink[]
}

enum TripStatus {
  PLANNING
  VOTING
  BOOKED
  ONGOING
  COMPLETED
}

model TripMember {
  id          String     @id @default(uuid())
  userId      String
  tripId      String
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime   @default(now())
  completedQuestionnaire Boolean @default(false)

  user        User     @relation(fields: [userId], references: [id])
  trip        Trip     @relation(fields: [tripId], references: [id])

  @@unique([userId, tripId])
}

enum MemberRole {
  ADMIN
  MEMBER
}

model Question {
  id          String       @id @default(uuid())
  text        String       @unique
  category    String
  type        QuestionType
  order       Int
  options     Json?
  isActive    Boolean      @default(true)

  answers     QuestionAnswer[]
}

enum QuestionType {
  SINGLE_CHOICE
  MULTI_CHOICE
  SCALE
  TEXT
}

model QuestionAnswer {
  id         String   @id @default(uuid())
  userId     String
  tripId     String
  questionId String
  answer     Json
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  question   Question @relation(fields: [questionId], references: [id])

  @@unique([userId, tripId, questionId])
}

model SuggestedDestination {
  id          String   @id @default(uuid())
  tripId      String
  name        String
  country     String
  description String
  whyItFits   String
  matchScore  Float
  climate     String?
  highlights  Json
  createdAt   DateTime @default(now())

  trip        Trip     @relation(fields: [tripId], references: [id])
  votes       DestinationVote[]
}

// ===== הוצאות (Splitwise) =====

model TripExpense {
  id           String   @id @default(uuid())
  tripId       String
  paidByUserId String
  amount       Float
  currency     String   @default("ILS")
  exchangeRate Float    @default(1)   // כמה שקלים שווה יחידת מטבע
  amountILS    Float                  // amount * exchangeRate
  description  String
  category     String   @default("other")
  expenseDate  DateTime @default(now())
  createdAt    DateTime @default(now())

  trip         Trip                 @relation(fields: [tripId], references: [id])
  paidBy       User                 @relation("ExpensesPaid", fields: [paidByUserId], references: [id])
  participants ExpenseParticipant[]
}

model ExpenseParticipant {
  id        String      @id @default(uuid())
  expenseId String
  userId    String

  expense   TripExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
}

// ===== מפת טיול =====

model TripPlace {
  id        String   @id @default(uuid())
  tripId    String
  name      String
  lat       Float
  lng       Float
  notes     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  trip      Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  photos    PlacePhoto[]
}

model PlacePhoto {
  id        String    @id @default(uuid())
  placeId   String
  url       String
  caption   String?
  createdAt DateTime  @default(now())

  place     TripPlace @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

// ===== קישורים מרוכזים =====

enum TripLinkType {
  FLIGHT
  HOTEL
  CAR
  ACTIVITY
  RESTAURANT
  BAR
  MAP
  INSURANCE
  DOCUMENT
  PAYMENT
  OTHER
}

enum TripLinkStatus {
  SAVED
  PENDING
  BOOKED
  PAID
  MISSING
  CANCELLED
}

model TripLink {
  id                String         @id @default(uuid())
  tripId            String
  title             String
  description       String?
  url               String?
  type              TripLinkType   @default(OTHER)
  status            TripLinkStatus @default(SAVED)
  providerName      String?
  startDate         DateTime?
  endDate           DateTime?
  estimatedCost     Float?
  currency          String?
  responsibleUserId String?
  notes             String?
  isPinned          Boolean        @default(false)
  isPrivate         Boolean        @default(false)
  fileUrl           String?
  fileName          String?
  decisionId        String?
  createdByUserId   String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  trip      Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User @relation("LinksCreated", fields: [createdByUserId], references: [id])
}

model DestinationVote {
  id            String   @id @default(uuid())
  destinationId String
  userId        String
  score         Int
  createdAt     DateTime @default(now())

  destination   SuggestedDestination @relation(fields: [destinationId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@unique([destinationId, userId])
}

// ===== החלטות =====

enum DecisionStatus {
  VOTING
  DECIDED
}

enum DecisionType {
  YES_NO
  SINGLE_CHOICE
  MULTI_CHOICE
  TOP3
}

enum DecisionCategory {
  DESTINATION
  DATES
  HOTEL
  TRANSPORT
  ACTIVITY
  BUDGET
  OTHER
}

model Decision {
  id              String           @id @default(uuid())
  tripId          String
  title           String
  description     String?
  category        DecisionCategory @default(OTHER)
  status          DecisionStatus   @default(VOTING)
  type            DecisionType
  finalDecision   String?
  finalOptionId   String?
  dueDate         DateTime?
  actionNote      String?
  isSecretVote    Boolean          @default(false)
  createdByUserId String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  decidedAt       DateTime?

  trip      Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User             @relation("DecisionsCreated", fields: [createdByUserId], references: [id])
  options   DecisionOption[]
  votes     DecisionVote[]
}

model DecisionOption {
  id          String   @id @default(uuid())
  decisionId  String
  text        String
  description String?
  createdAt   DateTime @default(now())

  decision Decision       @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  votes    DecisionVote[]
}

model DecisionVote {
  id         String   @id @default(uuid())
  decisionId String
  optionId   String
  userId     String
  rank       Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  decision Decision       @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  option   DecisionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user     User           @relation("DecisionVotesByUser", fields: [userId], references: [id])

  @@unique([decisionId, optionId, userId])
}
