generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanTier {
  FREE
  PRO
  BUSINESS
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  /// Personal preference: use AI for timeline polish + smart notifications
  aiEnabled    Boolean  @default(true)
  /// Subscription tier
  plan         PlanTier @default(FREE)
  planExpiresAt DateTime?
  /// Total uploaded file bytes attributed to this user
  storageBytesUsed BigInt @default(0)
  createdAt    DateTime @default(now())

  trips                 TripMember[]
  expensesPaid          TripExpense[]          @relation("ExpensesPaid")
  expenseParticipations ExpenseParticipant[]
  decisionsCreated      Decision[]             @relation("DecisionsCreated")
  decisionVotes         DecisionVote[]         @relation("DecisionVotesByUser")
  linksCreated          TripLink[]             @relation("LinksCreated")
  timelineEvents        TimelineEvent[]        @relation("TimelineCreatedBy")
  flightsCreated        TripFlight[]           @relation("FlightsCreated")
  notifications         Notification[]
  usageMonths           UsageMonth[]
  biometricCredentials  BiometricCredential[]
}

model BiometricCredential {
  id          String   @id @default(uuid())
  userId      String
  credentialId String  @unique
  publicKey   String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Monthly usage counters (AI calls, etc.)
model UsageMonth {
  id        String   @id @default(uuid())
  userId    String
  /// Format YYYY-MM
  period    String
  aiCalls   Int      @default(0)
  /// Optional: bytes uploaded this month
  storageBytesAdded BigInt @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([userId])
}

/// Super-admin editable plan limits (overrides defaults in code)
model PlanConfig {
  id                  String  @id // FREE | PRO | BUSINESS
  nameHe              String
  maxTrips            Int
  maxMembersPerTrip   Int
  maxAiCallsPerMonth  Int
  maxStorageBytes     BigInt
  aiIncluded          Boolean @default(true)
  updatedAt           DateTime @updatedAt
}

model Trip {
  id              String     @id @default(uuid())
  name            String
  startDate       DateTime?
  endDate         DateTime?
  status          TripStatus @default(PLAN)
  inviteCode      String     @unique @default(uuid())
  defaultCurrency String     @default("ILS")
  ownerId         String     @default("")
  /// Trip-level AI switch (admin). When false, no AI for this trip.
  aiEnabled       Boolean    @default(true)
  createdAt       DateTime   @default(now())

  members           TripMember[]
  expenses          TripExpense[]
  decisions         Decision[]
  links             TripLink[]
  timelineEvents    TimelineEvent[]
  flights           TripFlight[]
  notifications     Notification[]

  places            Place[]
  scheduledEvents   ScheduledEvent[]
  mapPoints         MapPoint[]
}

enum TripStatus {
  PLAN
  LIVE
  FINISHED
  CANCELED
}

model TripMember {
  id       String     @id @default(uuid())
  userId   String
  tripId   String
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  user     User @relation(fields: [userId], references: [id])
  trip     Trip @relation(fields: [tripId], references: [id])

  @@unique([userId, tripId])
}

enum MemberRole {
  ADMIN
  MEMBER
}


// ===== הוצאות (Splitwise) =====

model TripExpense {
  id           String   @id @default(uuid())
  tripId       String
  paidByUserId String
  amount       Float
  currency     String   @default("ILS")
  exchangeRate Float    @default(1)   // כמה שקלים שווה יחידת מטבע
  amountILS    Float                  // amount * exchangeRate
  description  String
  category     String   @default("other")
  expenseDate  DateTime @default(now())
  createdAt    DateTime @default(now())

  trip         Trip                 @relation(fields: [tripId], references: [id])
  paidBy       User                 @relation("ExpensesPaid", fields: [paidByUserId], references: [id])
  participants ExpenseParticipant[]
}

model ExpenseParticipant {
  id        String      @id @default(uuid())
  expenseId String
  userId    String

  expense   TripExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
}

// ===== קישורים מרוכזים =====

enum TripLinkType {
  FLIGHT
  HOTEL
  CAR
  ACTIVITY
  RESTAURANT
  BAR
  MAP
  INSURANCE
  DOCUMENT
  PAYMENT
  OTHER
}

enum TripLinkStatus {
  SAVED
  PENDING
  BOOKED
  PAID
  MISSING
  CANCELLED
}

model TripLink {
  id                String         @id @default(uuid())
  tripId            String
  title             String
  description       String?
  url               String?
  type              TripLinkType   @default(OTHER)
  status            TripLinkStatus @default(SAVED)
  providerName      String?
  startDate         DateTime?
  endDate           DateTime?
  estimatedCost     Float?
  currency          String?
  responsibleUserId String?
  notes             String?
  isPinned          Boolean        @default(false)
  isPrivate         Boolean        @default(false)
  fileUrl           String?
  fileName          String?
  decisionId        String?
  createdByUserId   String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  trip      Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User @relation("LinksCreated", fields: [createdByUserId], references: [id])
}

// ===== החלטות =====

enum DecisionStatus {
  VOTING
  DECIDED
}

enum DecisionType {
  YES_NO
  SINGLE_CHOICE
  MULTI_CHOICE
  TOP3
}

enum DecisionCategory {
  DESTINATION
  DATES
  HOTEL
  TRANSPORT
  ACTIVITY
  BUDGET
  OTHER
}

model Decision {
  id              String           @id @default(uuid())
  tripId          String
  title           String
  description     String?
  category        DecisionCategory @default(OTHER)
  status          DecisionStatus   @default(VOTING)
  type            DecisionType
  finalDecision   String?
  finalOptionId   String?
  dueDate         DateTime?
  actionNote      String?
  isSecretVote           Boolean          @default(false)
  hideResultsUntilClosed Boolean          @default(false)
  createdByUserId String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  decidedAt       DateTime?

  trip      Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User             @relation("DecisionsCreated", fields: [createdByUserId], references: [id])
  options   DecisionOption[]
  votes     DecisionVote[]
}

model DecisionOption {
  id          String   @id @default(uuid())
  decisionId  String
  text        String
  description String?
  createdAt   DateTime @default(now())

  decision Decision       @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  votes    DecisionVote[]
}

model DecisionVote {
  id         String   @id @default(uuid())
  decisionId String
  optionId   String
  userId     String
  rank       Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  decision Decision       @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  option   DecisionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user     User           @relation("DecisionVotesByUser", fields: [userId], references: [id])

  @@unique([decisionId, optionId, userId])
}

// ===== טיסות =====

model TripFlight {
  id                String    @id @default(uuid())
  tripId            String
  flightNumber      String
  flightDate        DateTime?
  direction         String    @default("outbound") // outbound | return | other
  airline           String?
  departureAirport  String?
  arrivalAirport    String?
  departureAt       DateTime?
  arrivalAt         DateTime?
  notes             String?
  liveData          Json?
  liveFetchedAt     DateTime?
  createdByUserId   String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  trip      Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User @relation("FlightsCreated", fields: [createdByUserId], references: [id])

  @@index([tripId])
  @@index([tripId, flightNumber])
}

// ===== ציר זמן =====

enum TimelineEventType {
  MEMBER_JOINED
  DECISION_CLOSED
  LINK_ADDED
  PLACE_ADDED
  EXPENSE_ADDED
  PHOTO_UPLOADED
  MEMORY
  AI_RECAP
  AI_NOTE
}

model TimelineEvent {
  id              String            @id @default(uuid())
  tripId          String
  type            TimelineEventType
  /// UI filter bucket: expenses | places | photos | decisions | documents | members | memory | ai
  category        String
  title           String
  description     String?
  emoji           String            @default("📌")
  isPrivate       Boolean           @default(false)
  /// True when title/description was written or polished by AI
  aiGenerated     Boolean           @default(false)
  createdByUserId String?
  refType         String?
  refId           String?
  metadata        Json?
  occurredAt      DateTime          @default(now())
  createdAt       DateTime          @default(now())

  trip      Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User? @relation("TimelineCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tripId, occurredAt])
  @@index([tripId, category])
  @@index([tripId, type])
}

// ===== התראות =====

model Notification {
  id        String   @id @default(uuid())
  userId    String
  tripId    String?
  type      String   @default("system") // system | ai | decision | expense | member | memory | flight
  title     String
  body      String?
  emoji     String   @default("🔔")
  href      String?
  isRead    Boolean  @default(false)
  /// True when text was AI-generated/polished
  aiGenerated Boolean @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip? @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@index([tripId])
}

// ===== NEW UNIFIED SCHEMA =====

// 1. UNIFIED PLACE/ACTIVITY TABLE
model Place {
  id           String   @id @default(uuid())
  tripId       String

  // Basic info
  name         String
  nameOriginal String?  // Original name if different (e.g., local language)
  description  String?  // description_he from CSV
  category     String   @default("other")
  emoji        String   @default("📌")
  color        String   @default("blue")

  // Location
  location     String?  // address from CSV
  lat          Float?
  lng          Float?

  // Google Places integration
  placeId      String?  // Google Place ID
  openingHours Json?    // Opening hours from Google Places API (JSON or simple text)
  rating       Float?   // Google rating
  ratingCount  Int?     // Number of ratings (rating_count)

  // URLs
  mapsUrl      String?  // google_maps_link
  url          String?  // website

  // Activity details
  cost         String?  // cost from CSV
  durationMins Int?     // Estimated duration (not in CSV, keep for compatibility)
  estimatedDuration String? // estimated_duration from CSV (text format)

  // Notes
  notes        String?  // notes from CSV

  // Metadata
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  trip              Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  scheduledEvents   ScheduledEvent[]
  mapPoints         MapPoint[]
  photos            PlacePhoto[]
  files             PlaceFile[]
  votes             PlaceVote[]

  @@index([tripId])
  @@index([tripId, name])
  @@index([tripId, category])
  @@index([placeId])
}

model PlacePhoto {
  id        String   @id @default(uuid())
  placeId   String
  url       String
  caption   String?
  createdAt DateTime @default(now())

  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
}

model PlaceFile {
  id           String   @id @default(uuid())
  placeId      String
  filename     String
  originalName String
  mimeType     String   @default("application/octet-stream")
  size         Int      @default(0)
  createdAt    DateTime @default(now())

  place        Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
}

model PlaceVote {
  id        String   @id @default(uuid())
  placeId   String
  userId    String
  tripId    String
  vote      String   // "👍", "👎", "❤️", etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, userId])
  @@index([tripId])
}

// 2. SCHEDULED EVENTS (Calendar/Planner)
model ScheduledEvent {
  id           String   @id @default(uuid())
  tripId       String
  placeId      String?  // FK to Place (null for generic events)

  // Schedule
  date         String   // YYYY-MM-DD
  startMinute  Int      @default(0)
  durationMins Int      @default(60)
  allDay       Boolean  @default(false)

  // Override place details if needed
  title        String?
  notes        String?
  color        String?

  // Opening hours validation
  openingHoursWarning Json?

  // Metadata
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  trip         Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  place        Place?   @relation(fields: [placeId], references: [id], onDelete: SetNull)
  files        ScheduledEventFile[]

  @@index([tripId, date])
  @@index([placeId])
}

model ScheduledEventFile {
  id           String         @id @default(uuid())
  eventId      String
  filename     String
  originalName String
  mimeType     String         @default("application/octet-stream")
  size         Int            @default(0)
  createdAt    DateTime       @default(now())

  event        ScheduledEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

// 3. MAP POINTS (Map order/route)
model MapPoint {
  id        String   @id @default(uuid())
  tripId    String
  placeId   String

  // Map display
  date      String?  // YYYY-MM-DD (optional)
  order     Int      @default(0)
  notes     String?

  // Metadata
  createdAt DateTime @default(now())

  // Relations
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([tripId, placeId, date])
  @@index([tripId, date, order])
  @@index([placeId])
}
