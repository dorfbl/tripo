generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime @default(now())

  trips                 TripMember[]
  expensesPaid          TripExpense[]          @relation("ExpensesPaid")
  expenseParticipations ExpenseParticipant[]
  decisionsCreated      Decision[]             @relation("DecisionsCreated")
  decisionVotes         DecisionVote[]         @relation("DecisionVotesByUser")
  linksCreated          TripLink[]             @relation("LinksCreated")
}

model Trip {
  id              String     @id @default(uuid())
  name            String
  startDate       DateTime?
  endDate         DateTime?
  status          TripStatus @default(PLAN)
  inviteCode      String     @unique @default(uuid())
  defaultCurrency String     @default("ILS")
  ownerId         String     @default("")
  createdAt       DateTime   @default(now())

  members           TripMember[]
  expenses          TripExpense[]
  places            TripPlace[]
  decisions         Decision[]
  links             TripLink[]
  plannerActivities PlannerActivity[]
  plannerEvents     PlannerEvent[]
}

enum TripStatus {
  PLAN
  LIVE
  FINISHED
  CANCELED
}

model TripMember {
  id       String     @id @default(uuid())
  userId   String
  tripId   String
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  user     User @relation(fields: [userId], references: [id])
  trip     Trip @relation(fields: [tripId], references: [id])

  @@unique([userId, tripId])
}

enum MemberRole {
  ADMIN
  MEMBER
}


// ===== הוצאות (Splitwise) =====

model TripExpense {
  id           String   @id @default(uuid())
  tripId       String
  paidByUserId String
  amount       Float
  currency     String   @default("ILS")
  exchangeRate Float    @default(1)   // כמה שקלים שווה יחידת מטבע
  amountILS    Float                  // amount * exchangeRate
  description  String
  category     String   @default("other")
  expenseDate  DateTime @default(now())
  createdAt    DateTime @default(now())

  trip         Trip                 @relation(fields: [tripId], references: [id])
  paidBy       User                 @relation("ExpensesPaid", fields: [paidByUserId], references: [id])
  participants ExpenseParticipant[]
}

model ExpenseParticipant {
  id        String      @id @default(uuid())
  expenseId String
  userId    String

  expense   TripExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
}

// ===== מפת טיול =====

model TripPlace {
  id        String   @id @default(uuid())
  tripId    String
  name      String
  lat       Float
  lng       Float
  notes     String?
  mapsUrl   String?
  date      String?
  order     Int      @default(0)
  category  String   @default("other")
  createdAt DateTime @default(now())

  trip      Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  photos    PlacePhoto[]
}

model PlacePhoto {
  id        String    @id @default(uuid())
  placeId   String
  url       String
  caption   String?
  createdAt DateTime  @default(now())

  place     TripPlace @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

// ===== קישורים מרוכזים =====

enum TripLinkType {
  FLIGHT
  HOTEL
  CAR
  ACTIVITY
  RESTAURANT
  BAR
  MAP
  INSURANCE
  DOCUMENT
  PAYMENT
  OTHER
}

enum TripLinkStatus {
  SAVED
  PENDING
  BOOKED
  PAID
  MISSING
  CANCELLED
}

model TripLink {
  id                String         @id @default(uuid())
  tripId            String
  title             String
  description       String?
  url               String?
  type              TripLinkType   @default(OTHER)
  status            TripLinkStatus @default(SAVED)
  providerName      String?
  startDate         DateTime?
  endDate           DateTime?
  estimatedCost     Float?
  currency          String?
  responsibleUserId String?
  notes             String?
  isPinned          Boolean        @default(false)
  isPrivate         Boolean        @default(false)
  fileUrl           String?
  fileName          String?
  decisionId        String?
  createdByUserId   String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  trip      Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User @relation("LinksCreated", fields: [createdByUserId], references: [id])
}

// ===== החלטות =====

enum DecisionStatus {
  VOTING
  DECIDED
}

enum DecisionType {
  YES_NO
  SINGLE_CHOICE
  MULTI_CHOICE
  TOP3
}

enum DecisionCategory {
  DESTINATION
  DATES
  HOTEL
  TRANSPORT
  ACTIVITY
  BUDGET
  OTHER
}

model Decision {
  id              String           @id @default(uuid())
  tripId          String
  title           String
  description     String?
  category        DecisionCategory @default(OTHER)
  status          DecisionStatus   @default(VOTING)
  type            DecisionType
  finalDecision   String?
  finalOptionId   String?
  dueDate         DateTime?
  actionNote      String?
  isSecretVote           Boolean          @default(false)
  hideResultsUntilClosed Boolean          @default(false)
  createdByUserId String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  decidedAt       DateTime?

  trip      Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User             @relation("DecisionsCreated", fields: [createdByUserId], references: [id])
  options   DecisionOption[]
  votes     DecisionVote[]
}

model DecisionOption {
  id          String   @id @default(uuid())
  decisionId  String
  text        String
  description String?
  createdAt   DateTime @default(now())

  decision Decision       @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  votes    DecisionVote[]
}

model DecisionVote {
  id         String   @id @default(uuid())
  decisionId String
  optionId   String
  userId     String
  rank       Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  decision Decision       @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  option   DecisionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user     User           @relation("DecisionVotesByUser", fields: [userId], references: [id])

  @@unique([decisionId, optionId, userId])
}

// ===== מתכנן טיול =====

model PlannerActivity {
  id           String   @id @default(uuid())
  tripId       String
  name         String
  emoji        String   @default("📌")
  location     String?
  description  String?
  durationMins Int      @default(60)
  cost         String?
  category     String   @default("other")
  mapsUrl      String?
  url          String?
  color        String   @default("blue")
  createdAt    DateTime @default(now())

  trip   Trip                  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  events PlannerEvent[]
  files  PlannerActivityFile[]
  votes  PlannerActivityVote[]
}

model PlannerActivityVote {
  id         String   @id @default(uuid())
  activityId String
  tripId     String
  userId     String
  vote       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  activity PlannerActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([tripId])
}

model PlannerActivityFile {
  id           String   @id @default(uuid())
  activityId   String
  filename     String
  originalName String
  mimeType     String   @default("application/octet-stream")
  size         Int      @default(0)
  createdAt    DateTime @default(now())

  activity PlannerActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model PlannerEvent {
  id           String   @id @default(uuid())
  tripId       String
  activityId   String?
  title        String
  date         String
  startMinute  Int      @default(0)
  durationMins Int      @default(60)
  color        String   @default("blue")
  notes        String?
  allDay       Boolean  @default(false)
  url          String?
  mapsUrl      String?
  cost         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trip     Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activity PlannerActivity?   @relation(fields: [activityId], references: [id], onDelete: SetNull)
  files    PlannerEventFile[]
}

model PlannerEventFile {
  id           String   @id @default(uuid())
  eventId      String
  filename     String
  originalName String
  mimeType     String   @default("application/octet-stream")
  size         Int      @default(0)
  createdAt    DateTime @default(now())

  event PlannerEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
}
